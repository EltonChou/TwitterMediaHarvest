        "jest-webextension-mock": "^4.1.1",
        "keep-a-changelog": "^3.0.2",
        "lint-staged": "^16.4.0",
        "mini-css-extract-plugin": "^2.10.2",
        "pinst": "^3.0.0",
        "playwright-bdd": "^8.5.0",
        "prettier": "^3.8.1",
        "prettier-eslint": "^16.4.2",
        "sass": "^1.99.0",
        "sass-loader": "^16.0.7",
