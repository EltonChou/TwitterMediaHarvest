        "dayjs": "^1.11.20",
        "dotenv-webpack": "^9.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "fake-indexeddb": "^6.2.5",
        "file-loader": "^6.2.0",
        "filemanager-webpack-plugin": "^10.0.1",
